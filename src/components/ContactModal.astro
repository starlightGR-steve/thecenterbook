<!-- CONTACT MODAL -->
<div class="modal-overlay" id="ctaModal" onclick="if(event.target===this)closeCTA()">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="ctaHeading">
    <button class="modal-close" onclick="closeCTA()" aria-label="Close">&times;</button>
    <div id="ctaForm">
      <h3 id="ctaHeading">Book a Demo</h3>
      <p class="modal-sub">Tell us a bit about your center and we'll be in touch shortly.</p>
      <label>Your name <span class="req">*</span></label>
      <input type="text" id="f_name" autocomplete="name">
      <label>Center name <span class="req">*</span></label>
      <input type="text" id="f_center" autocomplete="organization">
      <label>Email <span class="req">*</span></label>
      <input type="email" id="f_email" autocomplete="email">
      <label>Phone <span style="color:var(--neutral);font-weight:500">(optional)</span></label>
      <input type="tel" id="f_phone" autocomplete="tel">
      <label>Message</label>
      <textarea id="f_message" placeholder="Anything you'd like us to know?"></textarea>
      <button class="modal-submit" onclick="submitCTA()">Send</button>
    </div>
    <div id="ctaDone" class="modal-success" style="display:none">
      <div class="ok">&#10003;</div>
      <h3>Thanks, we've got it.</h3>
      <p class="modal-sub">Your message is on its way to the team. We'll reach out at the email you provided.</p>
      <button class="modal-submit" onclick="closeCTA()">Close</button>
    </div>
  </div>
</div>
